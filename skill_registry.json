    "sutui_mcp": {
      "name": "速推 MCP",
      "description": "图片生成、视频解析、语音合成、模型搜索等 AI 创作能力",
      "type": "upstream_mcp",
      "config": {
        "upstream_name": "sutui",
        "upstream_url_env": "CAPABILITY_SUTUI_MCP_URL",
        "upstream_url_default": "https://mcp.sutui.cc/mcp"
      },
      "capabilities": {
        "image.generate": {
          "description": "生成图片（统一能力入口）",
          "upstream": "sutui",
          "upstream_tool": "generate",
          "enabled": true,
          "is_default": true,
          "arg_schema": {
            "type": "object",
            "properties": {
              "prompt": {
                "type": "string",
                "description": "生成提示词"
              },
              "model": {
                "type": "string",
                "description": "可选，模型名"
              },
              "size": {
                "type": "string",
                "description": "可选，图像尺寸"
              }
            },
            "required": [
              "prompt"
            ]
          }
        },
        "task.get_result": {
          "description": "查询任务结果（统一能力入口）",
          "upstream": "sutui",
          "upstream_tool": "get_result",
          "enabled": true,
          "is_default": true,
          "arg_schema": {
            "type": "object",
            "properties": {
              "task_id": {
                "type": "string",
                "description": "速推任务 ID；JSON 字段名必须为 task_id（勿写 taskid）"
              }
            },
            "required": [
              "task_id"
            ]
          }
        },
        "sutui.search_models": {
          "description": "搜索速推可用模型与参数",
          "upstream": "sutui",
          "upstream_tool": "search_models",
          "enabled": true,
          "is_default": false,
          "arg_schema": {
            "type": "object",
            "properties": {
              "query": {
                "type": "string"
              },
              "category": {
                "type": "string",
                "enum": [
                  "image",
                  "video",
                  "audio",
                  "all"
                ]
              }
            }
          }
        },
        "sutui.speak": {
          "description": "语音合成和音色管理",
          "upstream": "sutui",
          "upstream_tool": "speak",
          "enabled": true,
          "is_default": false,
          "arg_schema": {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "enum": [
                  "synthesize",
                  "list_voices"
                ],
                "default": "synthesize"
              },
              "text": {
                "type": "string"
              },
              "voice_id": {
                "type": "string"
              }
            }
          }
        },
        "sutui.parse_video": {
          "description": "解析视频分享链接并获取下载地址",
          "upstream": "sutui",
          "upstream_tool": "parse_video",
          "enabled": true,
          "is_default": false,
          "arg_schema": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              }
            },
            "required": [
              "url"
            ]
          }
        },
        "sutui.guide": {
          "description": "获取速推模型教程与最佳实践",
          "upstream": "sutui",
          "upstream_tool": "guide",
          "enabled": true,
          "is_default": false,
          "arg_schema": {
            "type": "object",
            "properties": {
              "query": {
                "type": "string"
              }
            }
          }
        },
        "sutui.transfer_url": {
          "description": "将公网媒体直链转存到速推 CDN（本机 save-url 拉取 v3-tasks 视频失败时也会自动调用）。速推 type 仅有 image/audio：视频（含 mp4、v3-tasks）也请传 type=image；返回链常为 /mcp-images/、后缀可能 .jpg，以实际文件为准。音频用 audio。",
          "upstream": "sutui",
          "upstream_tool": "transfer_url",
          "enabled": true,
          "is_default": false,
          "arg_schema": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "description": "公网直链；可为图片或视频（如 v3-tasks 的 .mp4）。"
              },
              "type": {
                "type": "string",
                "enum": [
                  "image",
                  "audio"
                ],
                "default": "image",
                "description": "视频转存填 image，音频填 audio。"
              }
            },
            "required": [
              "url"
            ]
          }
        }
      },
      "tags": [
        "image",
        "video",
        "audio",
        "ai"
      ]
    },
