                "type": "string"
              },
              "analysis_model": {
                "type": "string"
              },
              "image_model": {
                "type": "string"
              },
              "output_dir": {
                "type": "string"
              },
              "isolate_job_dir": {
                "type": "boolean"
              }
            }
          }
        }
      },
      "tags": [
        "image",
        "ecommerce",
        "detail",
        "long-image",
        "comfly",
        "credential_package"
      ]
    },
    "ecommerce_publish_skill": {
      "name": "商品发布",
      "description": "5大电商平台商品发布助手：抖店、小红书千帆、1688、淘宝、拼多多。配置店铺账号后，会话中可调用素材生成技能生成主图和详情图，自动打开浏览器填写商品信息，等待用户确认后手动点发布。",
      "type": "builtin",
      "store_visibility": "popular",
      "status": "available",
      "capabilities": {
        "ecommerce.publish": {
          "description": "电商商品发布：自动打开对应平台商家后台的商品创建页面，填写商品信息（标题、主图、详情图、价格等），但不自动提交，等待用户手动确认发布。",
          "upstream": "local",
          "upstream_tool": "invoke",
          "enabled": true,
          "is_default": false,
          "unit_credits": 0,
          "arg_schema": {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "enum": ["open_product_form", "list_shop_accounts"],
