{
  "packages": {
    "media_edit_skill": {
      "name": "素材剪辑",
      "description": "对素材库视频/图片做叠字、裁剪、画幅、静音、配乐、静图转视频、抽帧；需本机已安装 ffmpeg。在对话中用自然语言描述剪辑意图即可调用。",
      "type": "builtin",
      "store_visibility": "popular",
      "status": "available",
      "default_installed": true,
      "capabilities": {
        "media.edit": {
          "description": "本地素材剪辑（invoke_capability capability_id=media.edit）",
          "upstream": "local",
          "upstream_tool": "invoke",
          "enabled": true,
          "is_default": false,
          "unit_credits": 0,
          "arg_schema": {
            "type": "object",
            "properties": {
              "operation": {
                "type": "string",
                "enum": [
                  "overlay_text",
                  "trim",
                  "scale_pad",
                  "mute",
                  "mux_audio",
                  "image_to_video",
                  "extract_frame"
                ]
              },
              "asset_id": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "position": {
                "type": "string",
                "enum": [
                  "top",
                  "center",
                  "bottom"
                ]
              },
              "vertical_align": {
                "type": "string",
                "enum": [
                  "top",
                  "center",
                  "bottom"
                ]
              },
              "horizontal_align": {
                "type": "string",
                "enum": [
                  "left",
                  "center",
                  "right"
                ]
              },
              "margin_x": {
                "type": "integer"
              },
              "margin_y": {
                "type": "integer"
              },
              "offset_x": {
                "type": "integer"
              },
              "offset_y": {
                "type": "integer"
              },
              "font_size": {
                "type": "integer"
              },
              "font_color": {
                "type": "string"
              },
              "font_alpha": {
                "type": "number"
              },
              "font_file": {
                "type": "string"
              },
              "x_expr": {
                "type": "string"
              },
              "y_expr": {
                "type": "string"
              },
              "box": {
                "type": "boolean"
              },
              "box_color": {
                "type": "string"
              },
              "box_alpha": {
                "type": "number"
              },
              "box_border_width": {
                "type": "integer"
              },
              "border_width": {
                "type": "integer"
              },
              "border_color": {
                "type": "string"
              },
              "shadow_x": {
                "type": "integer"
              },
              "shadow_y": {
                "type": "integer"
              },
              "shadow_color": {
                "type": "string"
              },
              "shadow_alpha": {
                "type": "number"
              },
              "line_spacing": {
                "type": "integer"
              },
              "text_align": {
                "type": "string",
                "enum": [
                  "left",
                  "center",
                  "right"
                ]
              },
              "fix_bounds": {
                "type": "boolean"
              },
              "start_sec": {
                "type": "number"
              },
              "end_sec": {
                "type": "number"
              },
              "aspect_ratio": {
                "type": "string",
                "enum": [
                  "9:16",
                  "16:9",
                  "1:1",
                  "4:3",
                  "3:4"
                ]
              },
              "fit_mode": {
                "type": "string",
                "enum": [
                  "contain",
                  "cover"
                ]
              },
              "audio_asset_id": {
                "type": "string"
              },
              "duration_sec": {
                "type": "number"
              },
              "timestamp_sec": {
                "type": "number"
              }
            },
            "required": [
              "operation",
              "asset_id"
            ]
          }
        }
      },
      "tags": [
        "video",
        "image",
        "edit",
        "ffmpeg"
      ]
    },
    "comfly_veo_skill": {
      "name": "爆款TVC",
      "description": "用一张商品/主图自动做多分镜 + 多段 Veo 成片，可选拼接为一条 TVC；用户对话里可说「用爆款TVC和这个素材做个视频」。技能卡片**必须**在本账号下配置 Comfly 的 API Key 与 API 根地址（每用户独立，不走服务端环境变量兜底），分镜、提示词、模型与拼接由技能内置流程完成，无需用户在卡片里改流水线参数。下方 package_config 中的模型字段仅供系统/高级覆盖，普通用户可忽略。无需算力解锁。技术说明：提示词走 OpenAI 兼容 chat（根地址常为 https://ai.comfly.chat/v1）；视频任务走 Comfly v2（POST /v2/videos/generations，以官方文档为准）。",
      "type": "builtin",
      "store_visibility": "popular",
      "status": "available",
      "package_config": {
        "comfly_api_base": "https://ai.comfly.chat/v1",
        "video_model": "veo3.1",
        "analysis_model": "gemini-2.5-pro",
        "aspect_ratio": "9:16",
        "enhance_prompt": true,
        "storyboard_image_model": "nano-banana-2",
        "image_request_style": "openai_images"
      },
      "capabilities": {
        "comfly.daihuo": {
          "description": "（单段/分步调试）Comfly + Veo 图生视频：invoke_capability(capability_id=comfly.daihuo，payload.action=upload|generate_prompts|submit_video|poll_video)。成片优先用 comfly.daihuo.pipeline。",
          "upstream": "local",
          "upstream_tool": "invoke",
          "enabled": true,
          "is_default": false,
          "unit_credits": 0,
          "arg_schema": {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "enum": [
                  "upload",
                  "generate_prompts",
                  "submit_video",
                  "poll_video"
                ],
                "description": "upload: 本机 asset_id 上传得 image_url；generate_prompts: 从 image_url 生成 5 条英文视频 prompt；submit_video: 提交 Veo 任务；poll_video: 查询 task_id 状态与 output"
              },
              "asset_id": {
                "type": "string",
                "description": "upload 时必填"
              },
              "image_url": {
                "type": "string",
                "description": "generate_prompts/submit_video 时可用"
              },
              "prompt": {
                "type": "string",
                "description": "submit_video 视频提示词"
              },
              "task_id": {
                "type": "string",
                "description": "poll_video 必填"
              },
              "video_model": {
                "type": "string",
                "description": "覆盖卡片默认 Veo 模型"
              },
              "analysis_model": {
                "type": "string",
                "description": "覆盖卡片默认分析模型"
              },
              "aspect_ratio": {
                "type": "string",
                "description": "如 9:16、16:9"
              },
              "enhance_prompt": {
                "type": "boolean",
                "description": "非英文 prompt 时是否增强"
              }
            },
            "required": [
              "action"
            ]
          }
        },
        "comfly.daihuo.pipeline": {
          "description": "爆款TVC 整包成片：action=start_pipeline + asset_id（或 image_url）+ auto_save=true 即可，MCP 自动轮询至完成并入库；run_pipeline 为同步长请求；poll_pipeline+job_id 查进度。",
          "upstream": "local",
          "upstream_tool": "invoke",
          "enabled": true,
          "is_default": false,
          "unit_credits": 0,
          "arg_schema": {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "enum": [
                  "run_pipeline",
                  "start_pipeline",
                  "poll_pipeline"
                ]
              },
              "job_id": {
                "type": "string"
              },
              "asset_id": {
                "type": "string"
              },
              "image_url": {
                "type": "string"
              },
              "merge_clips": {
                "type": "boolean"
              },
              "storyboard_count": {
                "type": "integer"
              },
              "auto_save": {
                "type": "boolean"
              },
              "isolate_job_dir": {
                "type": "boolean"
              },
              "platform": {
                "type": "string"
              },
              "country": {
                "type": "string"
              },
              "language": {
                "type": "string"
              },
              "output_dir": {
                "type": "string"
              }
            }
          }
        }
      },
      "tags": [
        "video",
        "comfly",
        "veo",
        "i2v",
        "爆款TVC",
        "TVC",
        "credential_package"
      ]
    },
    "comfly_ecommerce_detail_skill": {
      "name": "电商详情页",
