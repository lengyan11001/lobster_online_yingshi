{
  "image.generate": {
    "description": "生成图片（文生图/图生图）。速推统一 generate 入口，返回 task_id 后用 task.get_result 取结果。",
    "upstream": "sutui",
    "upstream_tool": "generate",
    "enabled": true,
    "is_default": true,
    "arg_schema": {
      "type": "object",
      "properties": {
        "prompt": {
          "type": "string",
          "description": "生成提示词"
        },
        "model": {
          "type": "string",
          "description": "可选（省略时默认 fal-ai/flux-2/flash）"
        },
        "image_url": {
          "type": "string",
          "description": "图生图时传入图片 URL"
        },
        "image_size": {
          "type": "string",
          "description": "可选，如 square_hd, landscape_16_9"
        }
      },
      "required": [
        "prompt"
      ]
    }
  },
  "video.generate": {
    "description": "生成视频（文生视频或图生视频）。速推统一 generate 入口，返回 task_id 后用 task.get_result 轮询（通常 30–120 秒），服务端会自动长轮询。不同模型在 API 层参数可能不同（如 st-ai/super-seed2 有 functionMode/ratio 等），当前统一传 model+prompt+image_url+aspect_ratio+duration，由上游按 model 转成对应接口。",
    "upstream": "sutui",
    "upstream_tool": "generate",
    "enabled": true,
    "is_default": true,
    "arg_schema": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "description": "可选（省略时默认 sora2 即 fal-ai/sora-2/text-to-video）。用户说「用 Seedance」「用 wan」等即指定此字段。"
        },
        "prompt": {
          "type": "string",
          "description": "描述/动作提示词"
        },
        "image_url": {
          "type": "string",
          "description": "图生视频时必传，公开可访问的图片 URL；本地图可用 sutui.transfer_url 先转存"
        },
        "aspect_ratio": {
          "type": "string",
          "description": "可选，宽高比 16:9 或 9:16"
        },
        "duration": {
          "type": "integer",
          "description": "可选，视频时长秒数，如 5 或 10"
        }
      },
      "required": [
        "prompt"
      ]
    }
  },
  "task.get_result": {
    "description": "查询任务结果（统一能力入口）。参数 payload 内字段名必须为 task_id（下划线）。若任务仍在处理中（如视频生成），服务端会每 60 秒自动轮询一次，最多等待 30 分钟，无需重复调用。",
    "upstream": "sutui",
    "upstream_tool": "get_result",
    "enabled": true,
    "is_default": true,
    "arg_schema": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string",
          "description": "速推任务 ID；JSON 中字段名必须为 task_id，勿用 taskid"
        }
      },
      "required": [
        "task_id"
      ]
    }
  },
  "image.understand": {
    "description": "理解/分析图片内容（i2t）。通过多模态 LLM（Gemini / Claude 等）描述、识别、解读图片。返回文本而非图片。",
    "upstream": "sutui",
    "upstream_tool": "generate",
    "enabled": true,
    "is_default": true,
    "arg_schema": {
      "type": "object",
      "properties": {
        "prompt": {
          "type": "string",
          "description": "提问/指令，如「详细描述这张图片」「图中有什么文字」"
        },
        "image_url": {
          "type": "string",
          "description": "单张图片 URL（会自动转为 image_urls 数组）"
        },
        "image_urls": {
          "type": "array",
          "description": "图片 URL 数组（最多 10 张）"
        },
        "model": {
          "type": "string",
          "description": "底层 LLM，默认 google/gemini-3-pro-preview"
        }
      },
      "required": [
        "prompt"
      ]
    }
  },
  "video.understand": {
    "description": "理解/分析视频内容（v2t）。通过多模态 LLM（Gemini / Claude 等）描述、总结、解读视频。返回文本而非视频。",
    "upstream": "sutui",
    "upstream_tool": "generate",
    "enabled": true,
    "is_default": true,
    "arg_schema": {
      "type": "object",
      "properties": {
        "prompt": {
          "type": "string",
          "description": "提问/指令，如「这个视频讲了什么」「总结视频内容」"
        },
        "video_url": {
          "type": "string",
          "description": "单个视频 URL（会自动转为 video_urls 数组）"
        },
        "video_urls": {
          "type": "array",
          "description": "视频 URL 数组（最多 5 个，支持 mp4/mov/webm）"
        },
        "model": {
          "type": "string",
          "description": "底层 LLM，默认 google/gemini-3-pro-preview"
        }
      },
      "required": [
        "prompt"
      ]
    }
  },
  "sutui.search_models": {
    "description": "搜索速推可用模型与参数 Schema",
    "upstream": "sutui",
    "upstream_tool": "search_models",
    "enabled": true,
    "is_default": false,
    "arg_schema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "自由文本搜索"
        },
        "category": {
          "type": "string",
          "enum": [
            "image",
            "video",
            "audio",
            "all"
          ]
        },
        "capability": {
          "type": "string",
          "enum": [
            "t2i",
            "i2i",
            "t2v",
            "i2v",
            "v2v",
            "t2a",
            "stt",
            "i2t",
            "v2t"
          ]
        },
        "model_id": {
          "type": "string"
        }
      }
    }
  },
  "sutui.guide": {
    "description": "获取速推模型教程与最佳实践",
    "upstream": "sutui",
    "upstream_tool": "guide",
    "enabled": true,
    "is_default": false,
    "arg_schema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string"
        },
        "skill_id": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "image",
            "video",
            "audio",
            "tool"
          ]
        }
      }
    }
  },
  "sutui.account": {
    "description": "速推账户管理（余额/签到/套餐/支付）",
    "upstream": "sutui",
    "upstream_tool": "account",
    "enabled": true,
    "is_default": false,
    "arg_schema": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "balance",
            "checkin",
            "packages",
            "pay"
          ],
          "default": "balance"
        },
        "package_id": {
          "type": "integer"
        }
      }
    }
  },
  "sutui.parse_video": {
    "description": "解析视频分享链接并获取下载地址",
    "upstream": "sutui",
    "upstream_tool": "parse_video",
    "enabled": true,
    "is_default": false,
    "arg_schema": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string"
        }
      },
      "required": [
        "url"
      ]
    }
  },
  "sutui.transfer_url": {
    "description": "将公网媒体直链转存到速推 CDN（本机 save-url 拉取 v3-tasks 视频失败时也会自动调用）。同一源 URL、同一 task.get_result 已返回的成品：只调用一次，禁止连环重复转存（否则重复入库与扣费）。速推接口的 type 仅有 image / audio：视频（含 .mp4、v3-tasks 成品链）也请传 type=image，并非误用；返回 URL 常见路径为 /mcp-images/、后缀可能为 .jpg，以实际文件内容与 Content-Type 为准。音频必须用 type=audio。",
    "upstream": "sutui",
    "upstream_tool": "transfer_url",
    "enabled": true,
    "is_default": false,
    "arg_schema": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "description": "公网可访问的直链。可为图片，也可为视频（如 cdn-video…/v3-tasks/…/*.mp4）。"
        },
        "type": {
          "type": "string",
          "enum": [
            "image",
            "audio"
          ],
          "default": "image",
          "description": "速推仅支持 image 与 audio。转存视频时请填 image；仅音频填 audio。"
        }
      },
      "required": [
        "url"
      ]
    }
  },
  "sutui.speak": {
    "description": "语音合成和音色管理",
    "upstream": "sutui",
    "upstream_tool": "speak",
    "enabled": true,
    "is_default": false,
    "arg_schema": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "synthesize",
            "list_voices",
            "design_voice",
            "clone_voice"
          ],
          "default": "synthesize"
        },
        "text": {
          "type": "string"
        },
        "voice_id": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "audio_url": {
          "type": "string"
        },
        "file_id": {
          "type": "integer"
        },
        "voice_name": {
          "type": "string"
        },
        "model": {
          "type": "string",
          "enum": [
            "speech-2.8-hd",
            "speech-2.8-turbo",
            "speech-2.6-hd",
            "speech-2.6-turbo"
          ],
          "default": "speech-2.8-hd"
        },
        "speed": {
          "type": "number",
          "default": 1
        }
      }
    }
  },
  "media.edit": {
    "description": "本地素材剪辑：叠字、时间段裁剪、画幅比例、静音、视频配新音轨、静图转视频、视频抽帧；输出新 asset。需本机 ffmpeg。解锁见技能「素材剪辑」。",
    "upstream": "local",
    "upstream_tool": "invoke",
    "enabled": true,
    "is_default": false,
    "unit_credits": 0,
    "arg_schema": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "enum": [
            "overlay_text",
            "trim",
            "scale_pad",
            "mute",
            "mux_audio",
            "image_to_video",
            "extract_frame"
          ],
          "description": "操作类型"
        },
        "asset_id": {
          "type": "string",
          "description": "主素材 ID"
        },
        "text": {
          "type": "string",
          "description": "overlay_text 文案（必填）"
        },
        "position": {
          "type": "string",
          "enum": [
            "top",
            "center",
            "bottom"
          ],
          "description": "overlay_text 垂直位置（与 vertical_align 二选一，后者优先）"
        },
        "vertical_align": {
          "type": "string",
          "enum": [
            "top",
            "center",
            "bottom"
          ],
          "description": "overlay_text 垂直对齐，默认 top"
        },
        "horizontal_align": {
          "type": "string",
          "enum": [
            "left",
            "center",
            "right"
          ],
          "description": "overlay_text 水平对齐，默认 center"
        },
        "margin_x": {
          "type": "integer",
          "description": "overlay_text 左右边距（left/right 时有效）或水平基准，默认 40，范围 0–4000"
        },
        "margin_y": {
          "type": "integer",
          "description": "overlay_text 上下边距，默认 40，范围 0–4000"
        },
        "offset_x": {
          "type": "integer",
          "description": "overlay_text 在计算位置基础上额外偏移 X，默认 0，范围 -4000–4000"
        },
        "offset_y": {
          "type": "integer",
          "description": "overlay_text 在计算位置基础上额外偏移 Y，默认 0，范围 -4000–4000"
        },
        "font_size": {
          "type": "integer",
          "description": "overlay_text 字号，默认 48，范围 8–200"
        },
        "font_color": {
          "type": "string",
          "description": "overlay_text 字色：命名色或 #RRGGBB / 0xRRGGBB / 0xRRGGBBAA（含透明度时不要再用 font_alpha）"
        },
        "font_alpha": {
          "type": "number",
          "description": "overlay_text 字透明度 0–1，与 6 位色或命名色联用"
        },
        "font_file": {
          "type": "string",
          "description": "overlay_text 字体绝对路径 .ttf/.ttc/.otf；中文未指定时仍自动选 CJK 字体"
        },
        "x_expr": {
          "type": "string",
          "description": "overlay_text 自定义 ffmpeg x 表达式（须与 y_expr 同时出现，覆盖对齐/边距）"
        },
        "y_expr": {
          "type": "string",
          "description": "overlay_text 自定义 ffmpeg y 表达式"
        },
        "box": {
          "type": "boolean",
          "description": "overlay_text 是否绘制文字背景框"
        },
        "box_color": {
          "type": "string",
          "description": "overlay_text 背景色；0xRRGGBBAA 时不要同时传 box_alpha"
        },
        "box_alpha": {
          "type": "number",
          "description": "overlay_text 背景透明度 0–1，默认 0.5（非 8 位 hex 色时）"
        },
        "box_border_width": {
          "type": "integer",
          "description": "overlay_text 背景框边宽 0–80"
        },
        "border_width": {
          "type": "integer",
          "description": "overlay_text 文字描边宽度 0–40"
        },
        "border_color": {
          "type": "string",
          "description": "overlay_text 描边颜色"
        },
        "shadow_x": {
          "type": "integer",
          "description": "overlay_text 阴影 X 偏移 -120–120，与 shadow_y 均为 0 时不画阴影"
        },
        "shadow_y": {
          "type": "integer",
          "description": "overlay_text 阴影 Y 偏移 -120–120"
        },
        "shadow_color": {
          "type": "string",
          "description": "overlay_text 阴影颜色"
        },
        "shadow_alpha": {
          "type": "number",
          "description": "overlay_text 阴影透明度 0–1，默认 0.45"
        },
        "line_spacing": {
          "type": "integer",
          "description": "overlay_text 多行行距 -200–200"
        },
        "text_align": {
          "type": "string",
          "enum": [
            "left",
            "center",
            "right"
          ],
          "description": "overlay_text 多行水平对齐"
        },
        "fix_bounds": {
          "type": "boolean",
          "description": "overlay_text 是否将文字限制在画面内（ffmpeg fix_bounds）"
        },
        "start_sec": {
          "type": "number",
          "description": "trim 起始秒"
        },
        "end_sec": {
          "type": "number",
          "description": "trim 结束秒（须大于 start）"
        },
        "aspect_ratio": {
          "type": "string",
          "enum": [
            "9:16",
            "16:9",
            "1:1",
            "4:3",
            "3:4"
          ],
          "description": "scale_pad 目标比例"
        },
        "fit_mode": {
          "type": "string",
          "enum": [
            "contain",
            "cover"
          ],
          "description": "scale_pad：留边或裁切"
        },
        "audio_asset_id": {
          "type": "string",
          "description": "mux_audio 音频素材 ID"
        },
        "duration_sec": {
          "type": "number",
          "description": "image_to_video 时长（秒），最大 600"
        },
        "timestamp_sec": {
          "type": "number",
          "description": "extract_frame 截取时刻（秒）"
        }
      },
      "required": [
        "operation",
        "asset_id"
      ]
    }
  },
  "comfly.daihuo": {
    "description": "（技能「爆款TVC」内的单段/分步能力）Comfly + Veo 图生视频：本机 MCP 转发至后端。用户日常「用爆款TVC做视频」优先用 comfly.daihuo.pipeline。本能力：submit 走 Comfly POST /v2/videos/generations；poll_video 走 GET …/{task_id}（勿用 task.get_result）。upload|generate_prompts|submit_video|poll_video。勿与 video.generate（速推）混用。",
    "upstream": "local",
    "upstream_tool": "invoke",
    "enabled": true,
    "is_default": false,
    "unit_credits": 0,
    "arg_schema": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "upload",
            "generate_prompts",
            "submit_video",
            "poll_video"
          ],
          "description": "upload: asset_id→image_url；generate_prompts；submit_video；poll_video"
        },
        "asset_id": {
          "type": "string",
          "description": "upload 必填"
        },
        "image_url": {
          "type": "string",
          "description": "submit_video：单图 URL；与 images[] 二选一或同传"
        },
        "images": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "submit_video：Comfly 官方 images（1–3 张视 model），url 或 base64"
        },
        "prompt": {
          "type": "string",
          "description": "submit_video：英文提示词；与 prompts[] 二选一"
        },
        "prompts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "submit_video：可传 generate_prompts 返回的数组，后端取首条作为 prompt"
        },
        "enhance_prompt": {
          "type": "boolean",
          "description": "submit_video：true 时开启中文转英文等优化（Comfly enhance_prompt）"
        },
        "task_id": {
          "type": "string",
          "description": "poll_video：submit_video 返回的完整 task_id（如 video_…），后端请求 Comfly 查询接口"
        },
        "video_model": {
          "type": "string",
          "description": "Comfly Veo 模型名，如 veo3.1、veo3-pro-frames，勿填速推 st-ai/ 等"
        },
        "analysis_model": {
          "type": "string"
        },
        "aspect_ratio": {
          "type": "string",
          "description": "submit_video：9:16 或 16:9；不传则由上游按参考图推断"
        }
      },
      "required": [
        "action"
      ]
    }
  },
  "comfly.daihuo.pipeline": {
    "description": "技能「爆款TVC」整包成片：一次跑完分镜→多段 Veo→可选 FFmpeg 拼接；用户可说「用爆款TVC和这个素材做视频」。卡片只需配置 Comfly API Key/根地址，无需配分镜参数。action：start_pipeline（推荐：asset_id 或 image_url，MCP 自动轮询至完成，auto_save 默认入库）；run_pipeline（同步长请求，超时约 7200s）；poll_pipeline（查 job_id）。running 时 progress 来自 manifest.json。与 comfly.daihuo 分步独立。",
    "upstream": "local",
    "upstream_tool": "invoke",
    "enabled": true,
    "is_default": false,
    "unit_credits": 0,
    "arg_schema": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "run_pipeline",
            "start_pipeline",
            "poll_pipeline"
          ],
          "description": "run_pipeline：一次跑完（默认）；start_pipeline：后台任务 + 可轮询；poll_pipeline：查 job 状态"
        },
        "job_id": {
          "type": "string",
          "description": "poll_pipeline 必填；32 位 hex"
        },
        "asset_id": {
          "type": "string",
          "description": "run/start 时：素材库商品图 ID（与 image_url 二选一）"
        },
        "image_url": {
          "type": "string",
          "description": "run/start 时：公网商品图 URL（与 asset_id 二选一）"
        },
        "merge_clips": {
          "type": "boolean",
          "description": "是否拼接多段，默认 true"
        },
        "storyboard_count": {
          "type": "integer",
          "description": "分镜条数 1–8，默认脚本内 5"
        },
        "auto_save": {
          "type": "boolean",
          "description": "完成后是否将每段成功 mp4 入库，默认 true"
        },
        "isolate_job_dir": {
          "type": "boolean",
          "description": "start 时默认 true：输出隔离到 job_runs/<job_id>/ 便于 manifest 进度"
        },
        "platform": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "output_dir": {
          "type": "string",
          "description": "可选，流水线 runs 根目录"
        }
      }
    }
  },
  "comfly.ecommerce.detail_pipeline": {
    "description": "电商详情页生成流水线：商品主图自动分析卖点、生成多张竖版详情页、拼接长图、素材入库。action 可选 run_pipeline（同步）、start_pipeline（异步）、poll_pipeline（轮询）。",
    "upstream": "local",
    "upstream_tool": "invoke",
    "enabled": true,
    "is_default": false,
    "unit_credits": 0,
    "arg_schema": {
