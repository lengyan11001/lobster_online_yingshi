# ============================================
# Lobster Config（参考模板）
# 解压后若无 .env：运行 install.bat 会从本文件复制为 .env；请再填写 SECRET_KEY、各 API Key 等（勿提交真实密钥到仓库）。
# 生产 zip（pack_full_project.sh）仅含本模板，不含 pack_bundle.env。
# ============================================

SECRET_KEY=lobster-secret-change-me
DEBUG=true

DEFAULT_USER_EMAIL=user@lobster.local
DEFAULT_USER_PASSWORD=lobster123

# 数据库：默认 sqlite:///./lobster.db。使用 MySQL/PostgreSQL 时务必配置连接池，避免 QueuePool 耗尽超时
# DATABASE_URL=mysql+pymysql://user:pass@127.0.0.1:3306/lobster?charset=utf8mb4
# DB_POOL_SIZE=15
# DB_MAX_OVERFLOW=25
# DB_POOL_TIMEOUT=60
# DB_POOL_RECYCLE=280

HOST=0.0.0.0
PORT=8000
MCP_PORT=8001
# 素材文件对外 URL（图生视频必填）。速推服务器需能访问此地址拉图，否则会报 Failed to download
# 仅局域网时填本机 LAN 地址；速推在公网时需填公网 IP/域名或内网穿透(ngrok)地址
# 例: PUBLIC_BASE_URL=http://192.168.200.57:8000  或  https://xxx.ngrok.io
# 勿填 http://127.0.0.1:8000（同网段手机/其他电脑无法打开素材预览签名链）。
# 若暂时保留 127，请另设 LAN_PUBLIC_BASE_URL 为局域网根地址，例如：
# LAN_PUBLIC_BASE_URL=http://192.168.200.52:8000
# PUBLIC_BASE_URL=
# LAN_PUBLIC_BASE_URL=

# 对话模型 API Key（选填；不填则仅用 OpenClaw/速推）
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# 须与 openclaw/openclaw.json 里 gateway.auth.token 完全一致（龙虾 /chat 调 Gateway 用）
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=main
# 须与 openclaw/.env 中 OPENCLAW_SUTUI_PROXY_KEY 一致；生产请改为随机长串并同步两处
OPENCLAW_SUTUI_PROXY_KEY=lobster-oc-sutui-local-change-me
# 可选：强制 OpenClaw→认证中心 sutui-chat 的 model 字段（与网页速推子模型 id 一致）
# OPENCLAW_SUTUI_UPSTREAM_MODEL=deepseek-chat
# 以下为可选运维兜底（一般用户无需配置）：网页登录会自动写 openclaw/.channel_fallback.json 与 users.client_installation_id
# OPENCLAW_SUTUI_FALLBACK_JWT=
# OPENCLAW_SUTUI_FALLBACK_INSTALLATION_ID=
# OPENCLAW_PERSIST_CHANNEL_TOKEN_ON_LOGIN=true
# 微信助手：为 true（默认）时所有微信发信都按「当前网页登录」channel_fallback JWT 计费，无需 /myid 与 persist-weixin-openclaw-peer；多用户同机需按人扣费时改为 false
# OPENCLAW_WEIXIN_SINGLE_DEVICE_JWT=true
# 主对话是否先走 OpenClaw（默认 false，先直连+MCP）
# LOBSTER_OPENCLAW_PRIMARY_CHAT=true
# 仅 OpenClaw、失败不回退直连
# LOBSTER_OPENCLAW_ONLY_CHAT=true
# 为 true：无 /openclaw 等前缀时不因 PRIMARY 先走 OpenClaw；带前缀的该轮仍优先 OpenClaw
# LOBSTER_OPENCLAW_CHAT_PREFIX_GATE=true
# LOBSTER_OPENCLAW_CHAT_PREFIXES=/openclaw,/OPENCLAW
#
# openclaw/openclaw.json 中 mcp-gateway、lobster-sutui baseUrl 默认指向 http://127.0.0.1:PORT（与上列 PORT=8000 一致）；若改 PORT 请同步改 openclaw.json 与 openclaw/agents/*/agent/models.json

# 单机版直连速推 MCP；在线版可留空：LOBSTER_EDITION=online 且已设 AUTH_SERVER_BASE 时，本机 MCP 默认使用「认证中心/mcp-gateway」（服务器 SUTUI_SERVER_TOKEN 统一调上游）
CAPABILITY_SUTUI_MCP_URL=

# 在线版速推登录（LOBSTER_EDITION=online 时生效）
# SUTUI_OAUTH_LOGIN_URL=

# 微信服务号（服务器配置 + 网页授权，登录/回调均走服务器，本地无公网 IP 时填服务器地址）
# 公众平台 开发-基本配置：Token、EncodingAESKey；网页授权需 基本配置 的 AppID、AppSecret
# WECHAT_OA_TOKEN=
# WECHAT_OA_ENCODING_AES_KEY=
# WECHAT_OA_APP_ID=
# WECHAT_OA_SECRET=
# 回调与登录跳转根地址（必须为服务器公网地址，如 https://ts-api.fyshark.com）
# WECHAT_OA_BASE_URL=https://ts-api.fyshark.com

# 本仓库为在线客户端，运行时固定 online（可不配置此项；若写 standalone 也会被忽略为 online）
LOBSTER_EDITION=online

# 品牌标记：与 static/branding/brands.json 的 marks 键一致；首页标题/logo/文案与安装脚本桌面快捷方式图标、名称均由此决定
LOBSTER_BRAND_MARK=bihuo

# 纯代码包热更新（无 python/nodejs/deps）：HTTPS manifest；start 时若 ①服务端 build 更大 或 ②build 相同但 manifest.version 更高（如 1.0.0→1.0.1）则下载 zip 覆盖代码
# 服务端静态目录：/client/client-code/manifest.json（lobster_server client_static/client_code/）
# 不配置则不做任何网络请求
CLIENT_CODE_MANIFEST_URL=http://42.194.209.150/client/client-code/manifest.json

# 在线版：默认对话模型（sutui/<model>）
# LOBSTER_DEFAULT_SUTUI_CHAT_MODEL=deepseek-chat
# 定时编排使用的对话模型（tool_calls 遵从率更高）；不填则用默认对话模型
# LOBSTER_ORCHESTRATION_SUTUI_CHAT_MODEL=deepseek-chat

# 在线版：认证中心 = 公网 lobster_server（与 static/js/app.js 中 LOBSTER_SERVER_PUBLIC 一致）
AUTH_SERVER_BASE=http://42.194.209.150

# 在线版：本机 MCP / 本机后端代理请求公网 AUTH 的预扣、结算、退款时必填，与认证中心 lobster_server .env 中 LOBSTER_MCP_BILLING_INTERNAL_KEY 完全一致（否则会 403，无法生成）
# LOBSTER_MCP_BILLING_INTERNAL_KEY=

# Twilio WhatsApp Sandbox / 正式号：入站 Webhook（POST）签名校验
# Sandbox → Messaging → Sandbox →「When a message comes in」填公网 HTTPS，例如：
#   https://你的域名/api/twilio/whatsapp/inbound
# TWILIO_AUTH_TOKEN=（控制台 Account Auth Token）
# 反代或 URL 与 Starlette 看到的不一致时，填与 Twilio 配置完全相同的完整 URL：
# TWILIO_WHATSAPP_WEBHOOK_FULL_URL=https://你的域名/api/twilio/whatsapp/inbound
# 在线版：本机无 SID/Token 时，将 Twilio 配置/测试请求转发到海外 lobster_server（默认 http://43.162.111.36）；设为空可关闭
# TWILIO_REMOTE_API_BASE=http://43.162.111.36

# YouTube：在技能商店「YouTube 上传」进入账号列表，逐条配置 OAuth Client 与代理；若本机访问地址与 Google 回调不一致请设置 PUBLIC_BASE_URL

# 爆款TVC / Comfly：用户凭据仅在技能商店「爆款TVC」中配置，COMFLY_API_BASE/COMFLY_API_KEY 不作为用户 Key 的兜底。
# 以下仍可用于后端路由/联调（chat 路径、Veo v2 路径等），与每用户 Key 无关：
# COMFLY_API_BASE=https://ai.comfly.chat/v1
# COMFLY_API_KEY=
# 若官方路径不同，可覆盖相对路径（默认 chat/completions、video/jobs、video/jobs/{task_id}）：
# COMFLY_CHAT_COMPLETIONS_PATH=chat/completions
# COMFLY_VEO_SUBMIT_PATH=video/jobs
# COMFLY_VEO_POLL_PATH_TEMPLATE=video/jobs/{task_id}
# 本地联调：先运行 run_mock_comfly.bat，再设：
# COMFLY_API_BASE=http://127.0.0.1:8765/v1
# COMFLY_API_KEY=mock

# 发布自动化（Playwright）：本机网络慢、页面打开慢、易报「找不到上传控件」时可加大等待（无需改代码）
# PUBLISH_PLAYWRIGHT_TIMEOUT_SCALE=2
#   将导航/点击/选 file 等默认毫秒超时整体乘以 1～6（建议 2～3）
# PUBLISH_NAVIGATION_TIMEOUT_MS=120000
#   若设置则覆盖 page.goto 的超时（毫秒），优先级高于 SCALE
# PUBLISH_FILE_INPUT_WAIT_MS=90000
#   进入发布页后，轮询等待 file input 出现的总时长（毫秒）；默认约 45s×SCALE
